<UserControl x:Class="One.Toolbox.Views.DiffViewer.DiffViewerPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:och="using:One.Control.Helpers"
             xmlns:vm="using:One.Toolbox.ViewModels.DiffViewer"
             d:DesignHeight="520"
             d:DesignWidth="1000"
             x:DataType="vm:DiffViewerPageVM"
             mc:Ignorable="d">
    <Design.DataContext>
        <vm:DiffViewerPageVM />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" RowSpacing="8">
        <Border Padding="8" Background="#12000000" CornerRadius="6">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="总行数:" />
                <TextBlock FontWeight="Bold" Text="{Binding TotalLineCount}" />
                <TextBlock Text="差异行数:" />
                <TextBlock FontWeight="Bold" Foreground="#D94A4A" Text="{Binding ChangedLineCount}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <TextBlock FontWeight="SemiBold" Text="{Binding LeftFilePath}" TextTrimming="CharacterEllipsis" />
                <AvaloniaEdit:TextEditor Grid.Row="1"
                                         FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                         IsReadOnly="True"
                                         ShowLineNumbers="True"
                                         Text="{Binding LeftContent}"
                                         WordWrap="False"
                                         och:DragDropHelper.DropFilesCommand="{Binding DropLeftCommand}"
                                         DragDrop.AllowDrop="True" />
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="8">
                <TextBlock FontWeight="SemiBold" Text="{Binding RightFilePath}" TextTrimming="CharacterEllipsis" />
                <AvaloniaEdit:TextEditor Grid.Row="1"
                                         FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                         IsReadOnly="True"
                                         ShowLineNumbers="True"
                                         Text="{Binding RightContent}"
                                         WordWrap="False"
                                         och:DragDropHelper.DropFilesCommand="{Binding DropRightCommand}"
                                         DragDrop.AllowDrop="True" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
